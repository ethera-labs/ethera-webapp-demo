# Copy this file to .env and replace placeholders with your own values.
# Do not commit .env.

# Network mode: testnet | mainnet
VITE_COMPOSE_NETWORK=testnet

# ----------------------------
# Testnet config (example only)
# ----------------------------
VITE_TESTNET_LABEL=Custom Testnet
VITE_TESTNET_ROLLUP_A_CHAIN_ID=555555
VITE_TESTNET_ROLLUP_A_NAME=Rollup A
VITE_TESTNET_ROLLUP_A_RPC=https://rollup-a-rpc.example.com/
VITE_TESTNET_ROLLUP_A_EXPLORER=https://rollup-a-explorer.example.com/

VITE_TESTNET_ROLLUP_B_CHAIN_ID=666666
VITE_TESTNET_ROLLUP_B_NAME=Rollup B
VITE_TESTNET_ROLLUP_B_RPC=https://rollup-b-rpc.example.com/
VITE_TESTNET_ROLLUP_B_EXPLORER=https://rollup-b-explorer.example.com/

VITE_TESTNET_BRIDGE=0x1111111111111111111111111111111111111111
VITE_TESTNET_TOKEN_ADDRESS=0x2222222222222222222222222222222222222222
VITE_TESTNET_TOKEN_DECIMALS=18
VITE_TESTNET_TOKEN_SYMBOL=TKN
VITE_TESTNET_WETH_ADDRESS=0xA4cDD1d399555f85c4D55a7E242FA5c330b9aAC2

# Optional L1 -> L2 ETH funding config (EOA recipient)
VITE_TESTNET_L1_CHAIN_ID=11155111
VITE_TESTNET_L1_NAME=Sepolia
VITE_TESTNET_L1_RPC=https://ethereum-sepolia-rpc.publicnode.com
VITE_TESTNET_L1_EXPLORER=https://sepolia.etherscan.io/
VITE_TESTNET_L1_TO_ROLLUP_A_BRIDGE=0x3333333333333333333333333333333333333333
VITE_TESTNET_L1_TO_ROLLUP_B_BRIDGE=0x4444444444444444444444444444444444444444
VITE_TESTNET_L1_BRIDGE_MIN_GAS_LIMIT=200000

# Optional testnet AA contract overrides (leave empty to use SDK defaults)
VITE_TESTNET_ROLLUP_A_KERNEL_IMPL=
VITE_TESTNET_ROLLUP_A_KERNEL_FACTORY=
VITE_TESTNET_ROLLUP_A_MULTICHAIN_VALIDATOR=
VITE_TESTNET_ROLLUP_A_META_FACTORY=
VITE_TESTNET_ROLLUP_B_KERNEL_IMPL=
VITE_TESTNET_ROLLUP_B_KERNEL_FACTORY=
VITE_TESTNET_ROLLUP_B_MULTICHAIN_VALIDATOR=
VITE_TESTNET_ROLLUP_B_META_FACTORY=

# Optional paymaster configuration
# Set one of these patterns:
# 1) Explicit per-chain endpoints (highest priority)
# 2) Base endpoint + per-chain route names (dynamic mapping)
# 3) One shared endpoint for all chains
# Shared endpoint (if your paymaster supports one URL for all chains):
VITE_TESTNET_PAYMASTER_URL=
# Dynamic base endpoint:
VITE_TESTNET_PAYMASTER_BASE_URL=
# Dynamic route names (defaults to rollupA / rollupB if omitted):
VITE_TESTNET_ROLLUP_A_PAYMASTER_NAME=
VITE_TESTNET_ROLLUP_B_PAYMASTER_NAME=
# Chain-specific endpoints (recommended when each chain has a unique route):
VITE_TESTNET_ROLLUP_A_PAYMASTER_URL=https://paymaster.example.com/rpc/v1/rollupA
VITE_TESTNET_ROLLUP_B_PAYMASTER_URL=https://paymaster.example.com/rpc/v1/rollupB

# ----------------------------
# Mainnet scaffold (optional)
# ----------------------------
