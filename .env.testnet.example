VITE_COMPOSE_NETWORK=testnet
VITE_TESTNET_LABEL=Ethera Sepolia

# Token config (required: TOKEN_ADDRESS + WETH_ADDRESS)
VITE_TESTNET_TOKEN_ADDRESS=0xFe3d78...
VITE_TESTNET_TOKEN_DECIMALS=18
VITE_TESTNET_TOKEN_SYMBOL=TEST
# Optional: set to `cet` when the configured source token is already a CET/composable token.
# VITE_TESTNET_TOKEN_BRIDGE_MODE=erc20
VITE_TESTNET_WETH_ADDRESS=0xA4cDD1d399555f85c4D55a7E242FA5c330b9aAC2

# L1 bridge config (must provide both A and B)
VITE_TESTNET_L1_TO_ROLLUP_A_BRIDGE=0xF3504fc6AAB6Da84cc466bB707a109a8824a0c24
VITE_TESTNET_L1_TO_ROLLUP_B_BRIDGE=0x30Fdb3B0035828372a9Df4D2F6B66CA27529C9B0

# Required universal bridge route keys for SDK-first L2->L2 + return-route flows.
VITE_TESTNET_UNIVERSAL_L2_TO_L2_BRIDGE=0x57d93F3E2fD17E3e42A24F113D5728441Bf79cb3
VITE_TESTNET_ROLLUP_A_COMPOSE_L2_BRIDGE=0xa48CC954531A24c737f496C60daa44ABAd8475ab
VITE_TESTNET_ROLLUP_B_COMPOSE_L2_BRIDGE=0xcF29d49571A5Cd7350AE27951993e57a89743599
VITE_TESTNET_ROLLUP_A_COMPOSE_PORTAL=0xbc2e5a158b9d3ea5ff145ea261736ab0ca6517f9
VITE_TESTNET_ROLLUP_B_COMPOSE_PORTAL=0xd32ed6c0a353ae79e087890d0f86d53d78036055

# Optional paymaster (recommended pattern: base URL + default route names)
VITE_TESTNET_PAYMASTER_BASE_URL=https://paymaster.example.com/rpc/v1
VITE_TESTNET_ROLLUP_A_PAYMASTER_NAME=rollupA
VITE_TESTNET_ROLLUP_B_PAYMASTER_NAME=rollupB

# Recommended for first-time L1 -> L2 CET deployment cases.
VITE_TESTNET_L1_BRIDGE_MIN_GAS_LIMIT=2000000

# Recommended override for CET L2 -> L2 routes that may deploy a new CET on destination.
VITE_TESTNET_L2_TO_L2_DESTINATION_CALL_GAS_LIMIT=3000000
VITE_TESTNET_L2_TO_L2_DESTINATION_VERIFICATION_GAS_LIMIT=3500000
VITE_TESTNET_L2_TO_L2_DESTINATION_PRE_VERIFICATION_GAS=120000
